{
  "name": "@sporthub/root",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "yarn workspace @sporthub/api dev",
    "dev:web": "yarn workspace @sporthub/web dev",
    "build:web": "yarn workspace @sporthub/web build",
    "build": "yarn workspaces foreach -A run build",
    "test": "yarn workspaces foreach -A run test",
    "lint": "yarn workspaces foreach -A run lint",
    "db:migrate": "yarn workspace @sporthub/db migrate",
    "db:seed": "yarn workspace @sporthub/db seed",
    "db:reset": "yarn workspace @sporthub/db reset",
    "db:generate": "yarn workspace @sporthub/db generate",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@4.6.0",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "playwright": "^1.59.1"
  }
}
