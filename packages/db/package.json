{
  "name": "@sporthub/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "migrate": "tsx scripts/migrate.ts",
    "seed": "tsx scripts/seed.ts",
    "reset": "tsx scripts/reset-db.ts",
    "generate": "kysely-codegen --out-file src/types/db.d.ts",
    "build": "tsc"
  },
  "dependencies": {
    "dotenv": "^17.4.1",
    "kysely": "^0.28.15",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "kysely-codegen": "^0.20.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
